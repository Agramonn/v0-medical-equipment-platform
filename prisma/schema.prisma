generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType @default(PRIVATE_HOSPITAL)
  address   String?
  city      String
  state     String
  country   String           @default("México")
  phone     String?
  email     String?
  website   String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  equipment     Equipment[]
  serviceOrders ServiceOrder[]
  contracts     Contract[]
  contacts      OrganizationContact[]
}

enum OrganizationType {
  IMSS
  ISSSTE
  SEDENA
  PEMEX
  STATE_HOSPITAL
  PRIVATE_HOSPITAL
  CLINIC
  LABORATORY
  DISTRIBUTOR
}

model OrganizationContact {
  id             String       @id @default(cuid())
  name           String
  role           String
  email          String?
  phone          String?
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model EquipmentModel {
  id           String   @id @default(cuid())
  name         String   // e.g. "Anesthesia Machine"
  category     String   // e.g. "Anesthesia"
  manufacturer String   // e.g. "Penlon"
  model        String   // e.g. "Prima 320 Advance"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  units   Equipment[]
  manuals Manual[]
  contractCoverage ContractEquipment[]
  spareParts       SparePart[]
  checklistTemplates ChecklistTemplate[]
}

model Manual {
  id        String   @id @default(cuid())
  name      String
  category  String
  fileUrl   String?
  pages     Int?
  createdAt DateTime @default(now())

  equipmentModelId String
  equipmentModel   EquipmentModel @relation(fields: [equipmentModelId], references: [id], onDelete: Cascade)
}

model Equipment {
  id              String          @id @default(cuid())
  serialNumber    String          @unique
  assetNumber     String          @unique
  department      String
  location        String
  status          EquipmentStatus @default(OPERATIONAL)
  installDate     DateTime
  purchaseDate    DateTime
  nextServiceDate DateTime?
  lastServiceDate DateTime?
  hoursUsed       Int             @default(0)
  maxHours        Int             @default(0)
  contractType    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  equipmentModelId String
  equipmentModel   EquipmentModel @relation(fields: [equipmentModelId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  serviceOrders  ServiceOrder[]
  serviceHistory ServiceHistory[]
  warranties Warranty[]
  contractUnits      ContractEquipmentUnit[]
}

enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE
  OUT_OF_SERVICE
  NEEDS_ATTENTION
}

model ServiceOrder {
  id          String             @id @default(cuid())
  orderNumber String             @unique @default(cuid())
  type        ServiceOrderType
  status      ServiceOrderStatus @default(DRAFT)
  priority    Priority           @default(MEDIUM)
  title       String
  description String?

  // Scheduling
  scheduledAt     DateTime?
  estimatedHours  Float?
  serviceLocation String?
  completedAt     DateTime?
  closedAt        DateTime?

  // Scope of Work (Step 3 of the creation wizard)
  objectives         String?
  activities         String?
  requiredTools      String[]
  requiredParts      String[]
  safetyRequirements String?
  customerNotes      String?
  checklist          Json?

  // Completion requirements (Step 4 of the wizard)
  requirements Json?

  // Documentation / evidence (filled by engineer during execution)
  findings           String?
  rootCause          String?
  correctiveActions  String?
  recommendations    String?
  laborHours         Float?
  partsUsed          Json?
  measurements       Json?
  engineerSignedName String?
  engineerSignedAt   DateTime?
  customerSignedName String?
  customerSignedAt   DateTime?
  signedDocumentUrl  String?

  origin ServiceOrderOrigin @default(MANUAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipmentId    String
  equipment      Equipment    @relation(fields: [equipmentId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignedToId   String?
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User         @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id])

  serviceHistory ServiceHistory?
  timelineEvents ServiceOrderTimelineEvent[]
}

enum ServiceOrderType {
  PREVENTIVE_MAINTENANCE
  CORRECTIVE_MAINTENANCE
  CALIBRATION
  INSPECTION
  INSTALLATION
}

enum ServiceOrderStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  PENDING_PARTS
  PENDING_CUSTOMER
  COMPLETED
  PENDING_SIGNATURE
  CLOSED
}

enum ServiceOrderOrigin {
  MANUAL
  TICKET
  PM_PLAN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ServiceOrderTimelineEvent {
  id        String       @id @default(cuid())
  label     String
  role      TimelineRole
  note      String?
  createdAt DateTime     @default(now())

  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  byUserId       String?
  byUser         User?        @relation(fields: [byUserId], references: [id])
}

enum TimelineRole {
  SUPERVISOR
  ENGINEER
  SYSTEM
  CUSTOMER
}

model ServiceHistory {
  id            String           @id @default(cuid())
  type          ServiceOrderType @default(CORRECTIVE_MAINTENANCE)
  date          DateTime
  summary       String
  detail        String?
  partsReplaced String[]
  serviceTime   Float?
  findings      String?
  createdAt     DateTime         @default(now())

  equipmentId    String
  equipment      Equipment     @relation(fields: [equipmentId], references: [id])
  engineerId     String
  engineer       User          @relation(fields: [engineerId], references: [id])
  serviceOrderId String?       @unique
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ENGINEER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedOrders ServiceOrder[]
  createdOrders  ServiceOrder[]               @relation("ServiceOrderCreatedBy")
  timelineEvents ServiceOrderTimelineEvent[]
  serviceHistory ServiceHistory[]
}

enum UserRole {
  SUPERVISOR
  ENGINEER
}

model Contract {
  id             String         @id @default(cuid())
  contractNumber String         @unique
  type           ContractType
  status         ContractStatus @default(ACTIVE)
  clientId       String
  client         Organization   @relation(fields: [clientId], references: [id])
  startDate      DateTime
  endDate        DateTime
  totalValue     Float?
  currency       String         @default("MXN")
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  equipmentCoverage ContractEquipment[]
}

enum ContractType {
  PUBLIC_BID         // LICITACIÓN PÚBLICA
  DIRECT_AWARD       // ADJUDICACIÓN DIRECTA
  LIMITED_TENDER     // INVITACIÓN RESTRINGIDA
  LOAN_AGREEMENT     // COMODATO
  PRIVATE            // CONTRATO PRIVADO
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  DRAFT
}

model ContractEquipment {
  id               String        @id @default(cuid())
  contractId       String
  contract         Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  equipmentModelId String
  equipmentModel   EquipmentModel @relation(fields: [equipmentModelId], references: [id])
  coverageType     CoverageType
  pmVisitsPerYear  Int           @default(2)
  slaHours         Int           @default(48)
  includesParts    Boolean       @default(false)
  includesLabor    Boolean       @default(true)
  notes            String?
  createdAt        DateTime      @default(now())

  // Unidades específicas cubiertas — si está vacío, cubre TODAS las
  // unidades del modelo en ese hospital (útil para contratos generales)
  units            ContractEquipmentUnit[]
}

model ContractEquipmentUnit {
  id                  String            @id @default(cuid())
  contractEquipmentId String
  contractEquipment   ContractEquipment @relation(fields: [contractEquipmentId], references: [id], onDelete: Cascade)
  equipmentId         String
  equipment           Equipment         @relation(fields: [equipmentId], references: [id])

  @@unique([contractEquipmentId, equipmentId])
}

enum CoverageType {
  FULL_SERVICE
  PREVENTIVE_ONLY
  CORRECTIVE_ONLY
  LOAN_AGREEMENT //COMODATO
  WARRANTY
  PARTS_ONLY
}

model Warranty {
  id             String       @id @default(cuid())
  equipmentId    String
  equipment      Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  providerType   WarrantyProviderType
  providerName   String
  startDate      DateTime
  endDate        DateTime
  coverageType   WarrantyCoverageType
  notes          String?
  createdAt      DateTime     @default(now())
}

enum WarrantyProviderType {
  MANUFACTURER
  DISTRIBUTOR
  BOTH
}

enum WarrantyCoverageType {
  PARTS_ONLY
  LABOR_ONLY
  PARTS_AND_LABOR
}

model SparePart {
  id               String         @id @default(cuid())
  partNumber       String
  description      String
  manufacturer     String
  supplier         String?
  estimatedCost    Float?
  stock            Int            @default(0)
  reorderLevel     Int            @default(1)
  createdAt        DateTime       @default(now())

  equipmentModelId String
  equipmentModel   EquipmentModel @relation(fields: [equipmentModelId], references: [id], onDelete: Cascade)
}

model ChecklistTemplate {
  id               String                  @id @default(cuid())
  name             String
  serviceType      ServiceOrderType
  version          String                  @default("1.0")
  estimatedMinutes Int                     @default(60)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  equipmentModelId String
  equipmentModel   EquipmentModel          @relation(fields: [equipmentModelId], references: [id], onDelete: Cascade)

  items            ChecklistTemplateItem[]

  @@unique([equipmentModelId, serviceType])
}

model ChecklistTemplateItem {
  id               String              @id @default(cuid())
  order            Int
  section          String
  description      String
  expectedValue    String?
  unit             String?
  isCritical       Boolean             @default(false)
  requiresEvidence Boolean             @default(false)
  createdAt        DateTime            @default(now())

  templateId       String
  template         ChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
}