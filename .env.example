# =============================================================================
# Variables de entorno de ejemplo.
# Copia este archivo a `.env` y rellena los valores para correr en local.
#   cp .env.example .env
# =============================================================================

# Cadena de conexión a PostgreSQL (Neon).
# En local puedes usar la URL "pooled" de tu proyecto de Neon.
# En v0 / Vercel esto lo provee automáticamente la integración de Neon
# (variable NEON_DATABASE_URL), así que NO necesitas definirlo allí.
DATABASE_URL="postgresql://usuario:password@host/dbname?sslmode=require"

# Secreto para Auth.js (NextAuth v5). Genera uno con:
#   openssl rand -base64 32
AUTH_SECRET="reemplaza-con-un-secreto-aleatorio"
